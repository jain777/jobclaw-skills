# JobClaw Skills — optional API keys.
# Most skills need NONE (Claude is the engine). These only strengthen `find-jobs`.
# See ../docs/JOB_SEARCH.md for what each source adds and its caveats.

# --- Free baseline -------------------------------------------------
# Adzuna (free tier): https://developer.adzuna.com/
ADZUNA_APP_ID=
ADZUNA_APP_KEY=

# --- Freemium aggregator (best single source) ----------------------
# SerpApi Google Jobs (100 free searches/mo): https://serpapi.com/google-jobs-api
# Used by scripts/serpapi.py. Budget-capped by find-jobs (a few queries/run, not per-company).
SERPAPI_KEY=

# --- Fallback scraper for JS / enterprise-ATS career pages ---------
# Firecrawl renders JS and returns clean markdown for find-jobs to parse. Used by
# scripts/firecrawl.py as the fallback for iCIMS/Taleo/Oracle/SuccessFactors (no public API)
# and JS-only career pages. https://firecrawl.dev
FIRECRAWL_API_KEY=

# --- Premium / paid (more & better listings) -----------------------
# TheirStack (315k+ sources incl. 16k+ ATS): https://theirstack.com/ (adapter deferred)
THEIRSTACK_API_KEY=

# --- Optional: target companies for ATS-direct adapters ------------
# Comma-separated board tokens. Greenhouse: the token in boards.greenhouse.io/<token>.
# Lever: the company slug in jobs.lever.co/<slug>.
GREENHOUSE_BOARDS=
LEVER_COMPANIES=

# --- Only if running skills headlessly via the Agent SDK -----------
# (NOT needed in interactive Claude Code.)
# ANTHROPIC_API_KEY=
